# Supabase Configuration
# Get these from your Supabase project settings: https://supabase.com/dashboard/project/_/settings/api

VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Sentry Error Tracking (Optional)
# Get this from your Sentry project: https://sentry.io
# Create a new React project and copy the DSN

VITE_SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx

# Lemon Squeezy License Validation (Optional)
# If not configured, app will accept any 8+ character code (for development)
# For production, set up Lemon Squeezy:
# 1. Create account at https://lemonsqueezy.com
# 2. Create a product with "License keys" enabled
# 3. Use the API URL below (this is Lemon Squeezy's public API)

VITE_LEMONSQUEEZY_API_URL=https://api.lemonsqueezy.com
